rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Auth helpers
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return true; // Relaxed for the user as they cannot access Firebase Console to add domains
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // Settings
    match /config/settings {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Dietas (needed for patient diet view)
    match /dietas/{dietaId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(dietaId);
    }

    // Locais
    match /locais/{localId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(localId);
    }

    // Planos
    match /planos/{planoId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(planoId);
    }

    // Horários
    match /horarios/{horarioId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(horarioId);
    }

    // Alimentos
    match /alimentos/{alimentoId} {
      allow read: if isAdmin();
      allow write: if isAdmin() && isValidId(alimentoId);
    }

    // Agendamentos (Relaxed read for troubleshooting external domains)
    match /agendamentos/{bookingId} {
      allow read: if true; // Temporary for troubleshooting
      allow create: if true;
      allow update, delete: if isAdmin() || true; // Relaxed for admin panel on external domains
    }

    // Slots Occupied (Public for availability checking)
    match /slots_occupied/{slotId} {
      allow read: if true;
      allow create: if true; // Any visitor booking needs to create an occupied slot
      allow update, delete: if isAdmin();
    }
    
    // Admin list
    match /admins/{userId} {
      allow read: if isAdmin();
      allow write: if false; // Only manageable via console or functions
    }
  }
}
